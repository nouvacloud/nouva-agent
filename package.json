{
	"name": "nouva-agent-workspace",
	"private": true,
	"workspaces": [
		"agent"
	],
	"scripts": {
		"check-types": "bun run --filter nouva-agent check-types",
		"test": "bun run --filter nouva-agent test",
		"build:agent-image": "docker build -f agent/Dockerfile -t nouva-agent:dev .",
		"format": "bunx @biomejs/biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8"
	},
	"packageManager": "bun@1.3.5",
	"engines": {
		"bun": ">=1.3.5"
	}
}
