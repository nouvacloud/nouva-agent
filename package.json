{
	"name": "nouva-agent",
	"private": true,
	"workspaces": [
		"agent",
		"packages/*"
	],
	"scripts": {
		"check-types": "bun run --filter @nouvacloud/agent-protocol check-types && bun run --filter @nouvacloud/service-images check-types && bun run --filter nouva-agent check-types",
		"test": "bun test packages/agent-protocol/src/index.test.ts packages/service-images/src/images.test.ts",
		"build:agent-image": "docker build -f agent/Dockerfile -t nouva-agent:dev .",
		"format": "bunx @biomejs/biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8"
	},
	"packageManager": "bun@1.3.5",
	"engines": {
		"bun": ">=1.3.5"
	}
}
